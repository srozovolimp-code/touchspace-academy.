{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TouchSpace Academy module content",
  "type": "object",
  "required": ["версия_схемы", "метаданные", "учебный_контент", "тесты"],
  "properties": {
    "версия_схемы": {
      "type": "string"
    },
    "метаданные": {
      "type": "object",
      "required": ["курс", "модуль"],
      "properties": {
        "курс": {
          "type": "object",
          "required": ["идентификатор", "название"]
        },
        "модуль": {
          "type": "object",
          "required": ["идентификатор", "порядковый_номер", "название", "примерная_продолжительность_минут"]
        }
      }
    },
    "учебный_контент": {
      "type": "object",
      "required": ["страницы"],
      "properties": {
        "страницы": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      }
    },
    "тесты": {
      "type": "object",
      "required": ["тесты_страниц", "итоговый_тест_модуля"],
      "properties": {
        "тесты_страниц": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/test"
          }
        },
        "итоговый_тест_модуля": {
          "$ref": "#/$defs/test"
        }
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["идентификатор_страницы", "порядковый_номер", "название", "контент_страницы", "связанный_тест"],
      "properties": {
        "идентификатор_страницы": {
          "type": "string",
          "pattern": "^alpine-floor-advanced-block-[0-9]{2}-page-[0-9]{2}$"
        },
        "категория": {
          "enum": ["учебный_раздел", "учебная_страница"]
        },
        "порядковый_номер": {
          "type": "integer",
          "minimum": 1
        },
        "название": {
          "type": "string"
        },
        "цель_страницы": {
          "type": "string"
        },
        "контент_страницы": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/block"
          }
        },
        "связанный_тест": {
          "type": "string"
        }
      }
    },
    "block": {
      "type": "object",
      "required": ["идентификатор_блока", "тип_блока", "заголовок", "содержимое"],
      "properties": {
        "идентификатор_блока": {
          "type": "string"
        },
        "тип_блока": {
          "enum": ["уведомление", "текст", "таблица", "карточки", "алгоритм", "хронология", "примеры", "список"]
        },
        "заголовок": {
          "type": "string"
        },
        "содержимое": {
          "type": "object"
        }
      }
    },
    "test": {
      "type": "object",
      "required": ["идентификатор_теста", "категория", "название", "проходной_балл_процентов", "вопросы"],
      "properties": {
        "идентификатор_теста": {
          "type": "string"
        },
        "категория": {
          "type": "string"
        },
        "название": {
          "type": "string"
        },
        "проходной_балл_процентов": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "вопросы": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/question"
          }
        }
      }
    },
    "question": {
      "type": "object",
      "required": ["идентификатор", "тип_вопроса", "текст_вопроса", "правильный_ответ"],
      "properties": {
        "идентификатор": {
          "type": "string"
        },
        "тип_вопроса": {
          "enum": ["один_ответ", "несколько_ответов", "верно_неверно", "последовательность"]
        },
        "текст_вопроса": {
          "type": "string"
        },
        "варианты_ответа": {
          "type": "array"
        },
        "элементы_для_упорядочивания": {
          "type": "array"
        },
        "правильный_ответ": {
          "type": "object",
          "required": ["значение"]
        },
        "пояснение": {
          "type": "string"
        }
      }
    }
  }
}
